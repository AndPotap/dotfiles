## Singularity aliases
function sa-scratch { pushd ~/.scratch; runexec bash -l; popd; }
function sc {
  FNAME="${1:-$(basename $(pwd))}.ext3.gz"

  pushd "${OVERLAYDIR}"

  rsync -h --progress "${OVERLAYFS}" ./"${FNAME}"

  gunzip -v "${FNAME}"

  popd
}

## W&B aliases
alias wclean='rm -r *.log latest-run offline-run-* sweep-*'
alias ws='wandb sweep'
function wsync {
  pushd "${LOGDIR}/${1}"
  wandb sync --sync-all --clean wandb/
  popd
}

## Slurm aliases
alias sctrl='scontrol show job'
alias si='sinfo -lNe'
function slaunch {
  if [[ ! -z "${GPUS}" ]]; then
    __GRES="--gres=gpu:${GPUS}"
  fi
  if [[ ! -z "${ACCOUNT}" ]]; then
    __ACCOUNT="--account=${ACCOUNT}"
  fi
  if [[ ! -z "${ARRAY}" ]]; then
    __ARRAY="--array=${ARRAY}"
  fi
  if [[ ! -z "${NODELIST}" ]]; then
    __NODELIST="--nodelist=${NODELIST}"
  fi
  if [[ "${NODES:-1}" -gt 1 ]]; then
    __EXECMODE=multi
  fi
  sbatch --job-name=${JOB_NAME:-$(basename $(pwd))} ${__ACCOUNT} \
        --output="${LOGDIR}/slurm-%j.out" --error="${LOGDIR}/slurm-%j.err" \
        --exclude=${SBATCH_EXCLUDE_LIST} ${__NODELIST} ${__ARRAY} \
        --nodes=${NODES:-1} --ntasks=${NODES:-1} \
        --cpus-per-task=${CPUS:-4} ${__GRES} --mem=${MEM:-16}G --time=${HH:-16}:00:00 \
        ~/.local/bin/run${__EXECMODE}exec "${@}"
}
function sle { less "${LOGDIR}/slurm-${1}.err"; }
function slo { less "${LOGDIR}/slurm-${1}.out"; }
alias sq='squeue -u "${USER}" -o "%.8u %.40j %.8A %.7F %.7K %.5T %.3C %.14b %.7m %.7M %.9L %.8R"'
function ste { tail -n100 -f "${LOGDIR}/slurm-${1}.err"; }
function sto { tail -n100 -f "${LOGDIR}/slurm-${1}.out"; }
function swandb {
    cd ~/pactl
  WANDB_SWEEP_ID=${1}
  if [[ -z "${WANDB_SWEEP_ID}" ]]; then
    echo "Missing sweep id."
    exit 1
  fi
  JOB_NAME=${WANDB_SWEEP_ID} slaunch runwandb ${@}
}
function swandb-gpu { GPUS="${GPUS:-1}" swandb "${@}"; }
