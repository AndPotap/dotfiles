#   . "${HOME}/.bashrc"
# fi

IS_PEEL=$([[ "$(cat /proc/sys/kernel/hostname)" =~ ^(hlog)\-[0-9]+\.hpc\.nyu\.edu$ ]] && echo 1 || echo 0)
IS_CASSIO=$([[ "$(cat /proc/sys/kernel/hostname)" =~ ^.+cs\.nyu\.edu$ ]] && echo 1 || echo 0)
IS_GREENE=$([[ "$(cat /proc/sys/kernel/hostname)" =~ ^(log|ga|gr|gv|gm)\-?[0-9]+\.hpc\.nyu\.edu$ ]] && echo 1 || echo 0)
IS_GDTN=$([[ "$(cat /proc/sys/kernel/hostname)" =~ ^(dtn)\-[0-9]+\.hpc\.nyu\.edu$ ]] && echo 1 || echo 0)
IS_ORIE=$([[ "$(cat /proc/sys/kernel/hostname)" =~ ^(mint|gauss)$ ]] && echo 1 || echo 0)
IS_SINGULARITY=$([[ ! -z "${SINGULARITY_NAME}" ]] && echo 1 || echo 0)

## Init.
if [[ ${IS_SINGULARITY} == "1" ]]; then

  export CONDA_PKGS_DIR=/ext3/.conda/pkgs
  export CONDA_ENVS_DIR=/ext3/.conda/envs
  export OMP_NUM_THREADS=4

fi

if [[ ${IS_PEEL} == "1" ]]; then
  CLUSTERNAME=peel

  if [[ ${IS_SINGULARITY} == "0" ]]; then
    module purge
    module load python/gcc/3.7.9
  fi

  export BLOBDIR="${SCRATCH}"
  export OVERLAYFS=/scratch/work/public/overlay-fs-ext3/overlay-15GB-500K.ext3.gz
  export SIF=/scratch/work/public/singularity/cuda11.1.1-cudnn8-devel-ubuntu20.04.sif

  export HADOOP_EXE=/usr/bin/hadoop
  export HADOOP_LIBPATH=/opt/cloudera/parcels/CDH/lib
  export HADOOP_STREAMING=hadoop-mapreduce/hadoop-streaming.jar

elif [[ ${IS_GREENE} == "1" ]]; then

  CLUSTERNAME=greene

  if [[ ${IS_SINGULARITY} == "0" ]]; then
    module purge
    module load anaconda3/2020.07 singularity/3.7.4
  fi

  export BLOBDIR="${SCRATCH}"
  export OVERLAYFS=/scratch/work/public/overlay-fs-ext3/overlay-15GB-500K.ext3.gz
  export SIF=/scratch/work/public/singularity/cuda11.1.1-cudnn8-devel-ubuntu20.04.sif

  export SBATCH_EXCLUDE_LIST=cs001

  source /share/apps/anaconda3/2020.07/etc/profile.d/conda.sh

elif [[ ${IS_GDTN} == "1" ]]; then

  CLUSTERNAME=gdtn
  export BLOBDIR="${SCRATCH}"

elif [[ ${IS_CASSIO} == "1" ]]; then

  CLUSTERNAME=cassio

  if [[ ${IS_SINGULARITY} == "0" ]]; then
    module purge
    module load anaconda3 gcc-11.2 git-2.16
  fi

  export BLOBDIR=/misc/vlgscratch5/WilsonGroup/sanyam
  export OVERLAYFS=${BLOBDIR}/overlay-fs-ext3/overlay-15GB-500K.ext3.gz
  export SIF=${BLOBDIR}/singularity/cuda10.2-cudnn8-devel-ubuntu18.04.sif

  export SINGULARITY_BINDPATH=/opt,/misc/vlgscratch4/WilsonGroup,/misc/vlgscratch5/WilsonGroup
  export SINGULARITY_CACHEDIR=${BLOBDIR}

  export JUPYTER_DEFAULT_PORT=8842

  export SBATCH_EXCLUDE_LIST=rose[1-4],vine[3,6,11-12],hpc[1-8]

  source /opt/anaconda3/etc/profile.d/conda.sh

elif [[ ${IS_ORIE} == "1" ]]; then

  CLUSTERNAME=orie

  export OMP_NUM_THREADS=4
  export BLOBDIR="/data/users/${USER}"

  source "${BLOBDIR}/.conda/etc/profile.d/conda.sh"
fi

if [[ ${IS_SINGULARITY} == "1" ]]; then
  CLUSTERNAME="Singularity>${CLUSTERNAME}"
fi

export PS1="[${CLUSTERNAME}]\[\033[38;5;11m\]\u\[$(tput sgr0)\]@\h:\[$(tput sgr0)\]\[\033[38;5;6m\][\w]\[$(tput sgr0)\]: \[$(tput sgr0)\]"
export PATH="~/.local/bin:${PATH}"

export DATADIR="${BLOBDIR}/datasets"
export LOGDIR="${BLOBDIR}/logs"
export OVERLAYDIR="${BLOBDIR}/overlayfs"
export ASSETDIR="${BLOBDIR}/assets"
export XDG_CACHE_HOME="${BLOBDIR}/.cache"
if [[ -z "${CONDA_PKGS_DIR}" || -z "${CONDA_ENVS_DIR}" ]]; then
  export CONDA_PKGS_DIR="${BLOBDIR}/.conda/pkgs"
  export CONDA_ENVS_DIR="${BLOBDIR}/.conda/envs"
fi
if [[ -z "${JUPYTER_DEFAULT_PORT}" ]]; then
  export JUPYTER_DEFAULT_PORT=${JUPYTER_DEFAULT_PORT:-8843}
fi

# source "${HOME}/.env_keys"
source "${HOME}/.bash_aliases_san"

mkdir -p "${OVERLAYDIR}" "${DATADIR}" "${LOGDIR}" "${ASSETDIR}"
